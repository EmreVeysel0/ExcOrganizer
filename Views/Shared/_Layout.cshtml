@using Microsoft.AspNetCore.Authentication
<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ExcOrganizer</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        body {
            height: 100%;
            background-color: #f0f4f8;
            font-family: 'Segoe UI', sans-serif;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .navbar {
            background: linear-gradient(135deg, #1a73e8, #0d47a1) !important;
            box-shadow: 0 2px 8px rgba(0,0,0,0.2);
        }

        .navbar-brand {
            font-size: 1.4rem;
            font-weight: 700;
            letter-spacing: 1px;
        }

            .navbar-brand i {
                margin-right: 6px;
            }

        .nav-link {
            font-weight: 500;
        }

        .navbar .btn-outline-light {
            border-radius: 20px;
            padding: 4px 16px;
        }

        .main-container {
            max-width: 1100px;
            margin: 30px auto;
            padding: 0 15px;
            flex: 1;
            width: 100%;
        }

        footer {
            background-color: #1a73e8;
            color: white;
            text-align: center;
            padding: 14px;
            margin-top: auto;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand" href="/">   
                <i class="bi bi-globe2"></i> ExcOrganizer
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Trips" asp-action="Index">
                            <i class="bi bi-map"></i> Екскурзии
                        </a>
                    </li>
                </ul>

                <div class="d-flex gap-2 align-items-center">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <form action="/Identity/Account/Logout" method="post">
                            <input name="__RequestVerificationToken" type="hidden" value="@(Context.GetTokenAsync("access_token").Result ?? "")" />
                            <button type="submit" class="btn btn-outline-light btn-sm">
                                <i class="bi bi-box-arrow-right me-1"></i> Изход
                            </button>
                        </form>
                    }
                    else
                    {
                        <a class="btn btn-outline-light btn-sm" href="/Identity/Account/Login">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Вход
                        </a>
                        <a class="btn btn-light btn-sm text-primary fw-bold" href="/Identity/Account/Register">
                            <i class="bi bi-person-plus me-1"></i> Регистрация
                        </a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <div class="main-container">
        @RenderBody()
    </div>

    <footer>
        &copy; @DateTime.Now.Year ExcOrganizer &mdash; Всички права запазени
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>