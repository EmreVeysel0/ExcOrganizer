@model ExcOrganizer.Data.Models.Trip
@{
    ViewData["Title"] = "Редакция на екскурзия";
}

<div class="row justify-content-center">
    <div class="col-lg-7 col-md-9">

        <div class="card shadow border-0">
            <div class="card-header bg-warning text-dark py-3">
                <h4 class="mb-0">
                    <i class="bi bi-pencil-square me-2"></i>Редакция на екскурзия
                </h4>
            </div>

            <div class="card-body p-4">

                <p class="text-muted mb-4">Промени данните и натисни „Запази промените".</p>

                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-type me-1 text-primary"></i>Заглавие
                        </label>
                        <input asp-for="Title" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-geo-alt me-1 text-danger"></i>Дестинация
                        </label>
                        <input asp-for="Destination" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-card-text me-1 text-secondary"></i>Описание
                        </label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-currency-euro me-1 text-success"></i>Цена (€)
                            </label>
                            <input asp-for="Price" type="number" step="0.01" class="form-control" />
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-people me-1 text-info"></i>Места
                            </label>
                            <input asp-for="Seats" type="number" class="form-control" />
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Валута</label>
                            <input class="form-control bg-light" value="EUR" disabled />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-calendar-check me-1 text-primary"></i>Начална дата
                            </label>
                            <input asp-for="StartDate" type="date" class="form-control" />
                        </div>

                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-calendar-x me-1 text-danger"></i>Крайна дата
                            </label>
                            <input asp-for="EndDate" type="date" class="form-control" />
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning text-dark fw-semibold">
                            <i class="bi bi-floppy me-1"></i> Запази промените
                        </button>
                        <a class="btn btn-outline-secondary" href="/Trips">
                            <i class="bi bi-arrow-left me-1"></i> Назад
                        </a>
                    </div>

                </form>

            </div>
        </div>

    </div>
</div>