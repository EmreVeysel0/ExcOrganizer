@model ExcOrganizer.Data.Models.Trip
@{
    ViewData["Title"] = "Добави екскурзия";
}

<div class="row justify-content-center">
    <div class="col-lg-7 col-md-9">

        <div class="card shadow border-0">
            <div class="card-header bg-primary text-white py-3">
                <h4 class="mb-0">
                    <i class="bi bi-plus-circle me-2"></i>Добави екскурзия
                </h4>
            </div>

            <div class="card-body p-4">

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger d-flex align-items-center gap-2">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <span>@ViewBag.Error</span>
                    </div>
                }

                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-type me-1 text-primary"></i>Заглавие
                        </label>
                        <input name="Title" class="form-control" placeholder="напр. Екскурзия до Рим" value="@Model?.Title" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-geo-alt me-1 text-danger"></i>Дестинация
                        </label>
                        <input name="Destination" class="form-control" placeholder="напр. Рим, Италия" value="@Model?.Destination" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-card-text me-1 text-secondary"></i>Описание
                        </label>
                        <textarea name="Description" class="form-control" rows="4" placeholder="Кратко описание на екскурзията...">@Model?.Description</textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-currency-euro me-1 text-success"></i>Цена (€)
                            </label>
                            <input name="Price" type="number" step="0.01" class="form-control"
                                   placeholder="0.00"
                                   value="@(Model != null ? Model.Price.ToString() : "")" />
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-people me-1 text-info"></i>Места
                            </label>
                            <input name="Seats" type="number" class="form-control"
                                   value="@(Model != null && Model.Seats != 0 ? Model.Seats : 30)" />
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Валута</label>
                            <input class="form-control bg-light" value="EUR" disabled />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-calendar-check me-1 text-primary"></i>Начална дата
                            </label>
                            <input type="date" name="StartDate" class="form-control"
                                   value="@(Model != null && Model.StartDate != default ? Model.StartDate.ToString("yyyy-MM-dd") : "")" />
                        </div>

                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-calendar-x me-1 text-danger"></i>Крайна дата
                            </label>
                            <input type="date" name="EndDate" class="form-control"
                                   value="@(Model != null && Model.EndDate != default ? Model.EndDate.ToString("yyyy-MM-dd") : "")" />
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-floppy me-1"></i> Запази
                        </button>
                        <a class="btn btn-outline-secondary" href="/Trips">
                            <i class="bi bi-arrow-left me-1"></i> Назад
                        </a>
                    </div>

                </form>

            </div>
        </div>

    </div>
</div>