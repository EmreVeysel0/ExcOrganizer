@model ExcOrganizer.Data.Models.Trip
@{
    ViewData["Title"] = "Детайли";
}

<div class="row justify-content-center">
    <div class="col-lg-8 col-md-10">

        <div class="card shadow border-0">
            <div class="card-header bg-primary text-white py-3">
                <h4 class="mb-0">
                    <i class="bi bi-info-circle me-2"></i>@Model.Title
                </h4>
            </div>

            <div class="card-body p-4">

                @* Съобщения за успех / грешка *@
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success d-flex align-items-center gap-2">
                        <i class="bi bi-check-circle-fill fs-5"></i>
                        <span>@TempData["Success"]</span>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger d-flex align-items-center gap-2">
                        <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                        <span>@TempData["Error"]</span>
                    </div>
                }

                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                    <div>
                        <p class="mb-1 text-muted">
                            <i class="bi bi-geo-alt-fill text-danger me-1"></i>
                            Дестинация: <b class="text-dark">@Model.Destination</b>
                        </p>
                        <p class="mb-0 text-muted">
                            <i class="bi bi-people-fill text-info me-1"></i>
                            Свободни места: <b class="text-dark">@Model.Seats</b>
                        </p>
                    </div>
                    <div class="text-end">
                        <span class="badge bg-success fs-5 px-3 py-2">
                            <i class="bi bi-currency-euro me-1"></i>@Model.Price.ToString("0.00")
                        </span>
                    </div>
                </div>

                <hr />

                <div class="row mb-4">
                    <div class="col-md-6 mb-2">
                        <div class="p-3 bg-light rounded text-center">
                            <div class="small text-muted mb-1">
                                <i class="bi bi-calendar-check text-primary"></i> Начална дата
                            </div>
                            <div class="fs-5 fw-semibold">@Model.StartDate.ToString("dd.MM.yyyy")</div>
                        </div>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="p-3 bg-light rounded text-center">
                            <div class="small text-muted mb-1">
                                <i class="bi bi-calendar-x text-danger"></i> Крайна дата
                            </div>
                            <div class="fs-5 fw-semibold">@Model.EndDate.ToString("dd.MM.yyyy")</div>
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <h5 class="mb-2">
                        <i class="bi bi-card-text me-1 text-secondary"></i>Описание
                    </h5>
                    <div class="text-muted border rounded p-3 bg-light" style="white-space: pre-wrap;">@Model.Description</div>
                </div>

                <div class="d-flex flex-wrap gap-2 align-items-center">
                    <a class="btn btn-outline-secondary" href="/Trips">
                        <i class="bi bi-arrow-left me-1"></i> Назад
                    </a>

                    @* Бутон за резервация *@
                    @if (User.Identity != null && User.Identity.IsAuthenticated && !User.IsInRole("Administrator"))
                    {
                        @if (ViewBag.AlreadyBooked == true)
                        {
                            <button class="btn btn-secondary" disabled>
                                <i class="bi bi-check-circle me-1"></i> Вече резервирано
                            </button>
                        }
                        else if (Model.Seats <= 0)
                        {
                            <button class="btn btn-danger" disabled>
                                <i class="bi bi-x-circle me-1"></i> Няма свободни места
                            </button>
                        }
                        else
                        {
                            <form asp-action="Book" asp-route-id="@Model.Id" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-success">
                                    <i class="bi bi-cart-plus me-1"></i> Резервирай място
                                </button>
                            </form>
                        }
                    }
                    else if (User.Identity == null || !User.Identity.IsAuthenticated)
                    {
                        <a class="btn btn-success" href="/Identity/Account/Login?returnUrl=/Trips/Details/@Model.Id">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Влез за да резервираш
                        </a>
                    }

                    @if (User.IsInRole("Administrator"))
                    {
                        <a class="btn btn-outline-primary" href="/Trips/Edit/@Model.Id">
                            <i class="bi bi-pencil me-1"></i> Редакция
                        </a>
                        <a class="btn btn-outline-danger" href="/Trips/Delete/@Model.Id">
                            <i class="bi bi-trash me-1"></i> Изтрий
                        </a>
                    }
                </div>

            </div>
        </div>

    </div>
</div>